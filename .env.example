# Copy this file to ".env" and adjust as needed.
# The app runs fine with these defaults if you skip the .env file entirely.

# Port the server listens on
PORT=4000

# Secret used to sign JWT auth tokens. Use a long random string in production.
JWT_SECRET=change-this-to-a-long-random-secret-string

# How long an auth token stays valid
JWT_EXPIRES_IN=7d

# --- PayPal (optional) ---------------------------------------------------
# Leave blank to use the built-in "Place order" checkout. To enable real
# PayPal Buttons, create sandbox REST credentials at
# https://developer.paypal.com/dashboard/applications/sandbox and paste them here.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox
PAYPAL_CURRENCY=USD

# --- Stripe (optional) ---------------------------------------------------
# Leave blank to hide the card option. To enable Stripe Checkout, create
# test API keys at https://dashboard.stripe.com/test/apikeys and paste the
# secret key here. The webhook secret is only needed if you set up a webhook
# endpoint (recommended for production) at /api/payments/stripe/webhook.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=usd
